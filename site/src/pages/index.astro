---
import BaseLayout from '../layouts/BaseLayout.astro';
import GHLForm from '../components/GHLForm.astro';
import Img from '../components/Img.astro';
import { business, forms } from '../data/site';
import { cfBg } from '../data/images.mjs';

const heroImg = '/uploads/2024/07/7113LostForestDr-14.webp';
// Social-share image (jpg for maximum platform compatibility).
const ogImg = '/uploads/2023/09/608E.VictoriaTerrace-3.jpg';

// Title + meta carried over from the live WordPress home page
// (review count refreshed 2026-07 to match the displayed 130+).
const title = 'Trusted Painters In OKC | 130+ 5-Star Reviews | Hometown Painting';
const description =
  "Oklahoma City's trusted residential painters. 130+ five-star reviews, a 5-year written warranty, and free on-the-spot estimates across the OKC metro.";

const services = [
  { img: '/uploads/2023/09/608E.VictoriaTerrace-1-1.webp', title: 'Exterior Painting', body: 'Oklahoma weather is hard on paint. We do full prep (scrape, sand, caulk, prime) before any color goes on. Premium Sherwin-Williams. 5-year warranty.', href: '/exterior-painting-oklahoma-city/' },
  { img: '/uploads/2024/03/Interior-Painting-OKC5.webp', title: 'Interior Painting', body: 'Furniture protected, floors covered, walls patched and prepped. We leave your home cleaner than we found it. 5-year warranty.', href: '/interior-painting-okc/' },
  { img: '/uploads/2026/01/5616NW130thSt-Interior-9.webp', title: 'Cabinet Painting', body: 'Full disassembly, deglossing, and spray application for a factory-smooth finish that holds up to daily kitchen use. 2-year warranty.', href: '/cabinet-painting-okc/' },
  { img: '/uploads/2023/04/Fence-Staining-OKC.webp', title: 'Fence & Deck Staining', body: 'Proper cleaning and prep first, then premium stain to protect and restore your wood. 2-year warranty on stain work.', href: '/fence-staining-okc/' },
];

const reviews = [
  { text: "Matt & the team did exactly what they said they'd do. When the touch-up paint didn't match exactly, Matt made a special trip to get the exact match. Above & beyond impressive.", cite: 'Koree V. · Google Review' },
  { text: 'We are more than pleased with the work Matt Stone and crew performed. The communication was great — Matt kept in contact daily. We would definitely recommend Hometown Painting.', cite: 'Shelly B. · Google Review' },
  { text: 'The crew was efficient, professional, and respectful of our home — minimal mess and a thorough cleanup when they finished. Pricing was very fair for the work involved.', cite: 'Candace M. · Google Review' },
];

// Each card opens with a real worry we hear at estimates, then answers it with
// concrete proof (see brand/MESSAGING.md: lead with the fear, resolve with proof).
const why = [
  { icon: '📅', title: 'Will they actually show up?', body: "Yes, and you'll never have to wonder. Clear scheduling up front and daily updates from Matt while we work. No ghosting, no radio silence." },
  { icon: '🛡️', title: 'What if my home gets damaged?', body: "Floors covered, furniture protected, and a careful crew. We carry full liability and workers' comp insurance on every job." },
  { icon: '👥', title: "Who's going to be in my house?", body: 'The same long-tenured crew we trust year after year, not a rotating cast of subcontractors. And Matt personally checks the work.' },
  { icon: '📝', title: 'What if the paint fails?', body: 'Then we fix it, free. Premium Sherwin-Williams products backed by a written 5-year warranty on interior and exterior painting.' },
];

// Recent Work strip — a curated mix of exterior, interior, cabinet, and staining
// projects. Every tile links through to the full gallery.
const work = [
  { img: '/uploads/2023/09/608E.VictoriaTerrace-3.webp', alt: 'Exterior repaint of a stone and brick home in the OKC metro' },
  { img: '/uploads/2022/08/IMG_0174-min-scaled.webp', alt: 'Craftsman-style home exterior painted gray with crisp white trim' },
  { img: '/uploads/2023/09/9409SW32ndTer-Edited-1.webp', alt: 'Freshly painted interior with wood floors and detailed trim' },
  { img: '/uploads/2025/05/5613NE107thSt-Interior-25.webp', alt: 'Kitchen and laundry cabinets painted a soft sage green' },
  { img: '/uploads/2025/05/13521StonedaleDr-3-scaled.webp', alt: 'Front door painted a warm pink against fresh exterior trim' },
  { img: '/uploads/2023/04/Fence-Staining-OKC.webp', alt: 'Backyard privacy fence stained a rich brown by Hometown Painting' },
];
---
<BaseLayout
  title={title}
  description={description}
  image={ogImg}
  showRating={true}
  preloadHero={cfBg(heroImg)}
>
  <!-- HERO -->
  <section class="hero" style={`background-image: linear-gradient(rgba(27,42,74,0.85), rgba(27,42,74,0.68)), url('${cfBg(heroImg)}');`}>
    <div class="container">
      <div class="hero-copy">
        <h1>Professional Painters OKC Homeowners Trust</h1>
        <p class="hero-sub">
          No-shows, surprise bills, paint that fails in two summers &mdash; you've heard the
          stories. Hiring a painter shouldn't feel like a gamble. From the first estimate to the
          final walk-through, we keep you informed and in control: interior, exterior, cabinets,
          and staining across the OKC metro.
        </p>
        <ul class="trust-signals">
          <li>✓ {business.rating.value} Stars · {business.rating.count}+ Google Reviews</li>
          <li>✓ 5-Year Warranty, Interior &amp; Exterior</li>
          <li>✓ Fully Insured</li>
          <li>✓ Final Walk-Through Before You Pay the Balance</li>
        </ul>
        <div class="hero-ctas">
          <a href={business.phoneHref} class="cta-phone">Call {business.phoneDisplay}</a>
          <a href="#estimate" class="cta-secondary">Get Your Free Estimate →</a>
        </div>
        <p class="cta-note">Estimates are always free, with no obligation.</p>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trustbar">
    <div class="container trustbar-inner">
      <span class="trustbar-stars">★★★★★</span>
      <span class="trustbar-text"><strong>{business.rating.value} out of 5</strong> · {business.rating.count}+ Google Reviews</span>
      <span class="trustbar-sep" aria-hidden="true"></span>
      <span class="trustbar-item">Owner on Every Job</span>
      <span class="trustbar-sep" aria-hidden="true"></span>
      <span class="trustbar-item">Family-Owned &amp; OKC Local</span>
    </div>
  </section>

  <!-- MEET YOUR PAINTER (moved up: personal, family-first, before the sales sections) -->
  <section class="about">
    <div class="container about-inner">
      <div class="about-photo">
        <Img
          src="/uploads/2022/08/paint-owners-cropped-scaled.webp"
          alt="Matt and Rachel Stone, owners of Hometown Painting"
          width={600} height={450} sizes="(max-width: 768px) 100vw, 460px" />
      </div>
      <div class="about-copy">
        <p class="about-eyebrow">Meet Your Painter</p>
        <h2>A Family Business That Treats You Like Family</h2>
        <p>
          Hi, I'm Matt Stone. My grandpa Art was a painter his whole life, and he did it the
          old-fashioned way: do good work and treat people right. He handed those values down to
          me, along with his old paint sprayer, when I started Hometown Painting. That's still how
          we work today. You get a real person as your direct contact, daily updates while we
          paint, and a final walk-through with you before you pay the balance.
        </p>
        <div class="about-cta">
          <a href={business.phoneHref} class="cta-phone">Call {business.phoneDisplay}</a>
          <a href="/professional-painters-okc/" class="cta-secondary cta-secondary--dark">Learn More About Us →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ESTIMATE -->
  <section class="estimate" id="estimate">
    <div class="container estimate-inner">
      <div class="estimate-copy">
        <h2>Get Your Free Estimate</h2>
        <p class="estimate-lead">
          Tell us about your project and we'll respond within the hour. No pressure,
          no obligation.
        </p>
        <ul class="estimate-points">
          <li>✓ Matt walks your project with you and quotes it on the spot</li>
          <li>✓ A clear written price and warranty before any work starts</li>
          <li>✓ 25% deposit only, balance after your final walk-through</li>
        </ul>
        <p class="estimate-or">Prefer to talk now? <a href={business.phoneHref}>Call {business.phoneDisplay}</a></p>
      </div>
      <div class="estimate-form">
        <GHLForm formId={forms.homepage} title="Website Form - Homepage" height={560} />
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="container">
      <h2>What We Do</h2>
      <p class="section-sub">Every service backed by our process, our crew, and our warranty.</p>
      <div class="services-grid">
        {services.map((s) => (
          <a href={s.href} class="service-card">
            <Img class="service-photo" src={s.img} alt={`${s.title} project in the Oklahoma City metro`} width={600} height={400} sizes="(max-width: 768px) 100vw, 530px" />
            <div class="service-card-body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
              <span class="service-link">Learn more about {s.title.toLowerCase()} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RECENT WORK -->
  <section class="work">
    <div class="container">
      <div class="work-head">
        <div>
          <h2>Recent Work in the OKC Metro</h2>
          <p class="section-sub">A few of the homes we've transformed across Oklahoma City.</p>
        </div>
        <a href="/gallery/" class="work-viewall">View Full Gallery →</a>
      </div>
      <div class="work-grid">
        {work.map((w) => (
          <a href="/gallery/" class="work-tile" aria-label="View our project gallery">
            <Img src={w.img} alt={w.alt} width={600} height={400} sizes="(max-width: 768px) 50vw, 350px" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews">
    <div class="container">
      <div class="stars">★★★★★</div>
      <div class="rating-label">{business.rating.value} Stars · {business.rating.count}+ Google Reviews</div>
      <h2>What OKC Homeowners Say</h2>
      <div class="review-grid">
        {reviews.map((r) => (
          <div class="review-card">
            <div class="review-stars">★★★★★</div>
            <p>"{r.text}"</p>
            <cite>— {r.cite}</cite>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Owner intro moved up, just beneath the trust bar -->

  <!-- WHY HOMETOWN -->
  <section class="why">
    <div class="container">
      <h2>The Four Worries We Hear at Every Estimate</h2>
      <p class="section-sub">If you're thinking them too, that's normal. Here's how we take each one off your plate.</p>
      <div class="why-grid">
        {why.map((w) => (
          <div class="why-item">
            <div class="why-icon">{w.icon}</div>
            <h3>{w.title}</h3>
            <p>{w.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="areas">
    <div class="container">
      <h2>Serving the OKC Metro</h2>
      <p>{business.areas.join(' · ')}</p>
    </div>
  </section>

  <!-- SECONDARY CTA -->
  <section class="cta-bottom">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Free estimates, fast response, and a crew that treats your home like their own.</p>
      <a href={business.phoneHref} class="cta-phone">Call {business.phoneDisplay}</a>
      <p class="or-text">— or —</p>
      <a href="#estimate" class="btn-secondary">Get Your Free Estimate</a>
    </div>
  </section>
</BaseLayout>
