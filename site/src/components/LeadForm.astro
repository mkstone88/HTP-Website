---
// Estimate lead form — same markup/design as the PPC funnel form.
// TODO: wire `action` to the GHL webhook (currently in the WordPress script.js).
const { heading = 'Get Your Free Estimate', sub = "We'll respond within the hour." } = Astro.props;
---
<div class="hero-form">
  <h2>{heading}</h2>
  <p>{sub}</p>
  <form id="lead-form" action="#" method="POST" data-lead-form>
    <input type="text" name="name" placeholder="Your Name" aria-label="Your name" required />
    <div class="contact-fields">
      <input type="tel" name="phone" placeholder="Phone Number" aria-label="Phone number" id="field-phone" />
      <input type="email" name="email" placeholder="Email Address" aria-label="Email address" id="field-email" />
      <p class="contact-hint">Provide phone, email, or both</p>
      <p class="contact-error" data-contact-error>Please provide a phone number or email so we can reach you.</p>
    </div>
    <select name="service" aria-label="Service needed" required>
      <option value="" disabled selected>Service Needed</option>
      <option value="exterior">Exterior Painting</option>
      <option value="interior">Interior Painting</option>
      <option value="cabinets">Cabinet Refinishing</option>
      <option value="deck">Deck / Fence Staining</option>
      <option value="unsure">Not Sure Yet</option>
    </select>
    <button type="submit" class="btn-submit">Get My Free Estimate</button>
    <p class="form-privacy">🔒 No spam, ever. We'll only use your info to contact you about your free estimate.</p>
  </form>
</div>

<script is:inline>
  (function () {
    var form = document.querySelector('[data-lead-form]');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      var phone = form.querySelector('#field-phone');
      var email = form.querySelector('#field-email');
      var err = form.querySelector('[data-contact-error]');
      if (!phone.value.trim() && !email.value.trim()) {
        e.preventDefault();
        if (err) err.style.display = 'block';
      }
    });
  })();
</script>
